{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://buttery.app/contracts/v1/grocery-list.schema.json",
  "title": "GroceryList",
  "type": "object",
  "required": ["id", "ownerId", "mode", "typedText", "strokes", "createdAt", "updatedAt"],
  "properties": {
    "id": { "type": "string" },
    "ownerId": { "type": "string" },
    "mode": { "enum": ["TYPE", "DRAW"] },
    "typedText": { "type": "string" },
    "strokes": { "type": "array", "items": { "type": "object" } },
    "createdAt": { "type": "integer" },
    "updatedAt": { "type": "integer" },
    "schemaVersion": { "type": "integer", "const": 1 }
  },
  "additionalProperties": true
}
